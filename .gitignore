# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/

# uv — the lockfile IS committed for exact, reproducible installs.

# Built index artifacts (regenerated by build_index.py) stay out of git...
index/*.json
index/*.pkl
index/*.npy
index/*.index
!index/.gitkeep

# OS
.DS_Store
Thumbs.db
