# Copy to .env and fill in your real key — .env is git-ignored, never commit it.
OPENAI_API_KEY=your-key-here

# Embedding model used for both chunk indexing and query embedding.
EMBEDDING_MODEL=text-embedding-3-small

# Chat model used to generate the grounded answer from retrieved chunks.
OPENAI_MODEL=gpt-5.4-mini

# Retrieval: how many top chunks to feed the LLM as context.
TOP_K=4
